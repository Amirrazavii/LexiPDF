<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Vocabulary Manager</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <h1>Vocabulary Manager</h1>

    <h2>Add New Word</h2>
    <!-- کلاس filter-form را به اینجا هم دادم تا ظاهر مرتبی بگیرد -->
    <form id="add-word-form" class="filter-form">
        <input type="text" name="word" placeholder="Word" required>
        <input type="text" name="type" placeholder="Type">
        <input type="text" name="pos" placeholder="POS">
        <input type="text" name="translation" placeholder="Translation">
        <input type="text" name="example" placeholder="Example">
        <input type="text" name="context" placeholder="Context">
        <input type="number" name="page" placeholder="Book Page">
        <button type="submit">Add</button>
    </form>
    <div id="add-result" style="text-align: center; margin-bottom: 20px;"></div>

    <h2>Filter/Search</h2>
    <!-- اعمال کلاس شما -->
    <form id="filter-form" class="filter-form">
        <input type="text" id="search-word" placeholder="Search Word">
        <input type="text" id="filter-type" placeholder="Type">

        <!-- این فیلد حالا Book Page را می‌گیرد -->
        <input type="number" id="search-book-page" placeholder="Book Page" min="1">

        <select id="sort-by">
            <option value="word">Word</option>
            <option value="page">Page</option>
            <option value="type">Type</option>
        </select>
        <select id="sort-dir">
            <option value="asc">Asc</option>
            <option value="desc">Desc</option>
        </select>
        <button type="submit">Filter</button>
    </form>

    <table id="vocab-table">
        <thead>
            <tr>
                <th>Word</th>
                <th>Type</th>
                <th>POS</th>
                <th>Translation</th>
                <th>Example</th>
                <th>Context</th>
                <th>Page</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>

    <div class="pagination"></div>

    <script>
        const pageSize = 10;

        async function fetchAndRender(currentPage = 1) {
            const type = document.getElementById('filter-type').value;
            const word = document.getElementById('search-word').value;
            // گرفتن شماره صفحه کتاب
            const bookPage = document.getElementById('search-book-page').value;
            const sortBy = document.getElementById('sort-by').value;
            const sortDir = document.getElementById('sort-dir').value;

            // ساخت ایمن URL Parameters
            const queryParams = new URLSearchParams({
                page: currentPage,       // برای Skip/Limit در بک‌اند
                sortBy: sortBy,
                sortDir: sortDir
            });

            // فقط اگر کاربر مقداری وارد کرده بود، به URL اضافه کن
            if (type) queryParams.append('type', type);
            if (word) queryParams.append('word', word);
            if (bookPage) queryParams.append('bookPage', bookPage);

            try {
                const res = await fetch(`/api/search?${queryParams.toString()}`);
                const data = await res.json();
                const tbody = document.querySelector('#vocab-table tbody');
                tbody.innerHTML = '';

                if (data.vocabularies.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="8" style="text-align:center">No results found</td></tr>';
                } else {
                    data.vocabularies.forEach(item => {
                        const tr = document.createElement('tr');
                        tr.innerHTML = `
                            <td>${item.word || ''}</td>
                            <td>${item.type || ''}</td>
                            <td>${item.pos || ''}</td>
                            <td>${item.translation || ''}</td>
                            <td>${item.example || ''}</td>
                            <td>${item.context || ''}</td>
                            <td>${item.page || ''}</td>
                            <td><button class="delete-btn" data-id="${item._id}" style="color:red; cursor:pointer;">Delete</button></td>
                        `;
                        tbody.appendChild(tr);
                    });
                }

                renderPagination(data.total, currentPage);
            } catch (err) {
                console.error("Error fetching data:", err);
            }
        }

        function renderPagination(totalItems, currentPage) {
            const container = document.querySelector('.pagination');
            container.innerHTML = '';
            const totalPages = Math.ceil(totalItems / pageSize);

            if (totalPages <= 1) return;

            const createButton = (text, pageNum, isActive = false) => {
                const a = document.createElement('a');
                a.href = "#";
                a.textContent = text;
                if (isActive) a.classList.add('active');
                a.addEventListener('click', (e) => {
                    e.preventDefault();
                    fetchAndRender(pageNum);
                });
                container.appendChild(a);
            };

            const createDots = () => {
                const span = document.createElement('span');
                span.textContent = '...';
                container.appendChild(span);
            };

            // دکمه قبلی
            if (currentPage > 1) createButton('«', currentPage - 1);

            // منطق محدود کردن دکمه‌ها (جلوگیری از ساخت ۱۰۰ دکمه)
            const maxVisible = 5;
            let start = Math.max(1, currentPage - 2);
            let end = Math.min(totalPages, start + maxVisible - 1);

            if (end - start < maxVisible - 1) {
                start = Math.max(1, end - maxVisible + 1);
            }

            if (start > 1) {
                createButton(1, 1);
                if (start > 2) createDots();
            }

            for (let i = start; i <= end; i++) {
                createButton(i, i, i === currentPage);
            }

            if (end < totalPages) {
                if (end < totalPages - 1) createDots();
                createButton(totalPages, totalPages);
            }

            // دکمه بعدی
            if (currentPage < totalPages) createButton('»', currentPage + 1);
        }

        // Add form listener
        document.getElementById('add-word-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const body = Object.fromEntries(formData.entries());

            try {
                const res = await fetch('/api/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
                const data = await res.json();
                const addResult = document.getElementById('add-result');
                if (res.ok) {
                    addResult.innerHTML = `<span style="color:green; font-weight:bold;">Added: ${data.word}</span>`;
                    e.target.reset();
                    fetchAndRender(1);
                } else {
                    addResult.innerHTML = `<span style="color:red">${data.error}</span>`;
                }
            } catch (err) {
                document.getElementById('add-result').innerHTML = `<span style="color:red">${err.message}</span>`;
            }
        });

        // Filter form listener
        document.getElementById('filter-form').addEventListener('submit', e => {
            e.preventDefault();
            fetchAndRender(1);
        });

        // Delete listener (Event Delegation)
        document.querySelector('#vocab-table tbody').addEventListener('click', async (e) => {
            if (e.target.classList.contains('delete-btn')) {
                const id = e.target.dataset.id;
                if (!confirm('Are you sure you want to delete this word?')) return;

                try {
                    const res = await fetch(`/api/delete/${id}`, { method: 'DELETE' });
                    const data = await res.json();
                    if (data.success || res.ok) {
                        fetchAndRender(1); // برگشت به صفحه اول بعد از حذف
                    } else {
                        alert('Error: ' + (data.error || 'Failed to delete'));
                    }
                } catch (err) {
                    alert('Error: ' + err.message);
                }
            }
        });

        // لود اولیه جدول
        fetchAndRender();
    </script>
</body>

</html>